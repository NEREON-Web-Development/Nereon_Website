# NEREON Website — Shared Hosting SPA Configuration
# Works with: Plesk (Apache), cPanel (Apache), and any Apache-based host.
#
# This file handles the React Router "single page app" redirect rule.
# Without it, direct URL access (e.g. yourdomain.com/services) returns a 404.
#
# DEPLOY THIS FILE:
#   Place this .htaccess file in the root of your web directory on the server.
#   • Plesk  → upload to /httpdocs/
#   • cPanel → upload to /public_html/
#   The GitHub Actions FTP deploy will upload it automatically from the dist/ folder.
#
# If you are on Nginx instead of Apache, use this config block instead:
#   location / {
#       try_files $uri $uri/ /index.html;
#   }

Options -MultiViews
RewriteEngine On
RewriteBase /

# If the request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise redirect everything to index.html (React Router handles routing)
RewriteRule ^ index.html [QSA,L]
